{
  "expo": {
    "name": "Make Faceless Videos",
    "slug": "make-faceless-videos",
    "scheme": "mfv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF4EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.makefacelessvideos.app",
      "associatedDomains": [
        "applinks:makefacelessvideos.com",
        "applinks:www.makefacelessvideos.com",
        "applinks:app.makefacelessvideos.com",
        "activitycontinuation:app.makefacelessvideos.com",
        "webcredentials:makefacelessvideos.com"
      ],
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Make Faceless Videos uses your photos so you can upload videos and frames to generate from.",
        "NSPhotoLibraryAddUsageDescription": "Save generated videos and audio to your library.",
        "NSMicrophoneUsageDescription": "Record reference audio for voice cloning.",
        "CFBundleSpokenName": "Make Faceless Videos",
        "CFBundleDisplayName": "Faceless",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.makefacelessvideos.app",
      "adaptiveIcon": {
        "backgroundColor": "#FAF4EC",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "makefacelessvideos.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.makefacelessvideos.com",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "app.makefacelessvideos.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "mfv"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Make Faceless Videos uses your photos so you can upload videos and frames."
        }
      ],
      "expo-secure-store",
      "expo-image",
      [
        "expo-av",
        {
          "microphonePermission": "Record reference audio for voice cloning."
        }
      ],
      "expo-asset"
    ],
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single",
      "name": "Make Faceless Videos · AI Faceless Video Maker",
      "shortName": "Faceless",
      "description": "Make faceless videos with AI — script to narrated short with captions, voiceover, music, and dubbing. Free to start on web, iOS, and Android.",
      "themeColor": "#FAF4EC",
      "backgroundColor": "#FAF4EC",
      "lang": "en",
      "display": "standalone",
      "orientation": "portrait",
      "preferRelatedApplications": true
    },
    "extra": {
      "marketingUrl": "https://makefacelessvideos.com",
      "supportUrl": "https://makefacelessvideos.com/legal/support.html",
      "privacyUrl": "https://makefacelessvideos.com/legal/privacy.html"
    }
  }
}

{
  "name": "ghibli-studio",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web --output-dir dist && node scripts/enrich-web-html.js dist",
    "preview:web": "npx --yes serve dist",
    "build:site": "node scripts/build-articles.js",
    "preview:site": "npx --yes serve site -p 4180 --no-clipboard"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.12",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "expo": "~56.0.4",
    "expo-asset": "~56.0.14",
    "expo-av": "^16.0.8",
    "expo-blur": "~56.0.3",
    "expo-clipboard": "~56.0.3",
    "expo-constants": "~56.0.15",
    "expo-document-picker": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-image-picker": "~56.0.13",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-uuid": "^2.0.4",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "private": true
}
